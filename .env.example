# ============================================================================
# Boardroom — environment template.
# Copy to `.env` and fill in. NEVER commit a real .env (it is gitignored).
#
# SAFETY: scope every venue credential to TRADE ONLY. Withdrawals/transfers
# must be DISABLED on the exchange/broker side. The single most dangerous
# thing in this project is a trading key with withdrawal permission. Don't
# create one. See README "Credential scoping".
# ============================================================================

# ---- The master live switch -------------------------------------------------
# Defaults to false. The system runs the full decision loop in DRY-RUN until
# you flip this to true AFTER funding the accounts. Stubbed execution otherwise.
LIVE_TRADING=false

# ---- Daily checkpoint (when the CEO convenes, UTC HH:MM) ---------------------
# 19:00 UTC ≈ 3pm ET (summer) — INSIDE the equities session (closes 4pm ET) so
# the Directional/stock leg can fill. Crypto (Kraken) trades 24/7 either way.
# Off-hours live equity orders are auto-held by the market-hours guard.
CHECKPOINT_UTC=19:00

# ---- Hard risk caps (CEO cannot override these) -----------------------------
# PERCENT of current portfolio value — they scale as the account grows, so a $40
# cap at $200 becomes $400 at $2,000 (same 20%). Resolved to CAD against live
# equity at decision time. Enforced in code, outside any agent's control.
# The fiat the Kraken account actually holds — orders settle in this currency.
# CAD = execute on Kraken's CAD pairs (only ~5 coins have one). USD = execute
# on USD pairs (the whole ~37-coin universe). To switch to USD: convert your
# CAD to USD inside Kraken first, then set USD here. Risk/reporting stays in
# CAD either way (sizing converts at the live USDCAD rate; no rate = no trade).
ACCOUNT_BASE_CURRENCY=CAD
TOTAL_DEPLOYABLE_PCT=0.80         # max fraction agents may deploy out of the floor
PER_TRADE_MAX_PCT=0.20           # max fraction for any single trade
EVENT_HARD_CAP_PCT=0.05          # ceiling on the Event division (lottery)
DAILY_LOSS_LIMIT_PCT=0.06        # daily realized loss; breach -> force ALL to the floor
MAX_DRAWDOWN_PCT=0.15            # peak-to-trough; breach trips the circuit breaker
FEE_DRAG_LIMIT_PCT=0.05          # cumulative cost drag ceiling; breach -> de-risk
STARTING_PORTFOLIO_CAD=200       # reference value for resolving caps until live equity is wired

# ---- Anthropic (the agents' brain — required) -------------------------------
ANTHROPIC_API_KEY=
BOARDROOM_LLM_MODEL=claude-opus-4-8

# ---- Supabase (state + metrics — required; NO trading power) -----------------
# Project: "boardroom" DB (repurposed claude-alpha). URL is public; the service
# key is the secret — copy it from Supabase Dashboard > Settings > API.
SUPABASE_URL=https://qyaekaifodgiaxyztpdt.supabase.co
SUPABASE_SERVICE_KEY=

# ---- Kraken (Yield floor + Event) — Milestone 6 -----------------------------
# Enable: Query Funds, Query/Create/Cancel Orders, Staking. DISABLE Withdraw.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ---- Directional venue — Interactive Brokers (equities/ETFs) ----------------
# Session-based auth via the Client Portal Gateway: download + run the gateway
# locally and log in at https://localhost:5000 (no static API key). Requires an
# IBKR Pro account. Enable trading; DO NOT enable withdrawals/transfers.
IBKR_GATEWAY_URL=https://localhost:5000
IBKR_ACCOUNT_ID=

# ---- Market data (optional) — richer signals for Directional ----------------
MARKET_DATA_API_KEY=

# ---- Effort channel (Phase 3, optional) — DISABLED at launch ----------------
# EFFORT_* keys go here if/when the operating division is ever switched on.

# ---- Crypto-first (2026-07) --------------------------------------------------
# Equities are SUNSET by default: no stock scans, no recommendations. Flip true
# to resurrect the advisory stock leg (code is dormant, not deleted).
ENABLE_EQUITIES=false
# Max share of the portfolio ONE asset may hold across all open positions.
# Not a no-rebuy rule: the CEO can keep adding to a winner up to this ceiling,
# then the next-best coin gets the capital.
ASSET_MAX_EXPOSURE_PCT=0.20
# How many ideas may be funded in a single checkpoint (different assets only).
MAX_FUNDINGS_PER_CHECKPOINT=2
