# Copy this to `env.list` (which is gitignored) and fill in your IBKR login.
# env.list holds your brokerage password — never commit it.

IBEAM_ACCOUNT=your_ibkr_username
IBEAM_PASSWORD=your_ibkr_password

# --- Two-factor authentication (read this) ---------------------------------
# IBeam cannot bypass 2FA. Your options:
#  • PAPER account (DU…): no 2FA — IBeam runs fully unattended. Best for
#    validating Boardroom end to end before risking real money.
#  • LIVE account with IB Key (mobile app): on each (re)login IBKR sends a push
#    to your phone — approve it. Not fully hands-off, but close.
# See https://github.com/Voyz/ibeam/wiki/Two-Factor-Authentication for handlers.

# Optional niceties:
# IBEAM_LOG_LEVEL=INFO
# IBEAM_PAGE_LOAD_TIMEOUT=60
